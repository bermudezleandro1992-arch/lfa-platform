# Variables de entorno — SomosLFA
# Copiá este archivo como .env.local y completá con tus valores reales de Firebase Console

# ── Firebase Client SDK (público, va al navegador) ──────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lfaofficial
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase App Check (reCAPTCHA v3) ──────────────────────────────────────
# 1. Ir a https://console.cloud.google.com/security/recaptcha
# 2. Crear una clave de tipo "Score based (v3)" con tu dominio somoslfa.com + localhost
# 3. Pegar la SITE KEY aquí (la secret key NO va acá, se configura en Firebase Console)
# 4. En Firebase Console → App Check → Apps → registrar la app con esa site key
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ── Region detection (opcional — servicio externo de IP) ────────────────────
# Por defecto usa ipapi.co (30k req/día gratis).
# Para producción de alto tráfico, reemplazá con ip-api.com Pro o ipinfo.io
IP_API_BASE_URL=https://ipapi.co
