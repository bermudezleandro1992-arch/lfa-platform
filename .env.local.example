# Variables de entorno — SomosLFA
# Copiá este archivo como .env.local y completá con tus valores reales de Firebase Console

# ── Firebase Client SDK (público, va al navegador) ──────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lfaofficial
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Region detection (opcional — servicio externo de IP) ────────────────────
# Por defecto usa ipapi.co (30k req/día gratis).
# Para producción de alto tráfico, reemplazá con ip-api.com Pro o ipinfo.io
IP_API_BASE_URL=https://ipapi.co
