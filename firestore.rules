rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function authExists() {
      return request.auth != null && request.auth.uid != null;
    }

    function obtenerRol() {
      return authExists() ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol : null;
    }

    function esAdmin() {
      return authExists() && (request.auth.uid == "2bOrFxTAcPgFPoHKJHQfYxoQJpw1" || obtenerRol() == "admin");
    }

    function esCapitan() {
      return authExists() && (esAdmin() || obtenerRol() == "capitan");
    }

    function isOwner(uid) {
      return authExists() && request.auth.uid == uid;
    }

    match /usuarios/{userid} {
      // Lectura pública para ranking y contadores — datos sensibles protegidos por la app
      allow read: if true;
      allow create: if false;
      allow update: if isOwner(userid) &&
                    !request.resource.data.diff(resource.data).affectedKeys()
                      .hasAny(['rol','baneado','fair_play','number','es_afiliado','ganancias_afiliado','referido_por','bono_referido_entregado','ip_registro_referido'])
                    || esAdmin();
      allow delete: if esAdmin();
    }

    // ── Colección nueva Next.js ──────────────────────────
    match /tournaments/{id} {
      allow read: if true;
      allow create: if esAdmin();
      allow update: if esAdmin();
      allow delete: if esAdmin();
    }

    match /transactions/{id} {
      allow read: if authExists() && (isOwner(resource.data.userId) || esAdmin());
      allow create: if false;
      allow update, delete: if false;
    }

    match /matches/{id} {
      allow read: if true; // público para ver resultados en tiempo real
      allow write: if false;
    }

    match /disputas/{id} {
      allow read: if authExists();
      allow write: if false;
    }

    match /torneos/{torneoId} {
      allow create: if esAdmin();
      allow delete: if esAdmin();
      allow update: if esCapitan() &&
                    request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['resultado_pendiente','estado_resultado','estado','disputa_activa','ganador_final'])
                    || esAdmin();

      match /mensajes/{mensajeId} {
        allow read: if authExists();
        allow create: if authExists();
        allow delete: if esAdmin();
      }
    }

    match /reportes_ia/{reporteId} {
      allow read: if esAdmin();
      allow create: if authExists();
      allow update: if esAdmin();
      allow delete: if esAdmin();
    }

    match /pagos/{pagoId} {
      allow read: if authExists() && (isOwner(resource.data.usuario_uid) || esAdmin());
      allow create, update, delete: if false;
    }

    match /pagos_pendientes/{pagoId} {
      allow read: if authExists() && (isOwner(resource.data.uid) || esAdmin());
      allow create, update, delete: if false;
    }

    match /pagos_procesados/{pagoId} {
      allow read: if authExists() && (isOwner(resource.data.uid) || esAdmin());
      allow create, update, delete: if false;
    }

    match /retiros/{retiroId} {
      allow read: if authExists() && (isOwner(resource.data.uid) || esAdmin());
      allow create, update, delete: if false;
    }

    match /torneo/{resultadoId} {
      allow read: if true;
      allow write: if false;
    }

    match /clubes_pro/{clubId} {
      allow read: if true;
      allow create: if esAdmin();
      allow update: if authExists() && (isOwner(resource.data.capitan_uid) || esAdmin());
      allow delete: if esAdmin();
    }

    match /equipos_coop/{clubId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /sorteos/{sorteoId} {
      allow read: if true;
      allow create, update, delete: if false;
    }

    match /configuracion/{docId} {
      allow read: if docId == 'stats_publicos' || esAdmin();
      allow write: if esAdmin();
    }

    match /estadisticas/{docId} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /chat_global/{msgId} {
      allow read: if authExists();
      allow create: if authExists()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.texto is string
                    && request.resource.data.texto.size() >= 1
                    && request.resource.data.texto.size() <= 280
                    && request.resource.data.keys().hasAll(['uid', 'texto', 'nombre', 'ts'])
                    && request.resource.data.keys().size() <= 8;
      allow update: if false;
      allow delete: if authExists() && (isOwner(resource.data.uid) || esAdmin());
    }

    match /equipos_efootball/{equipoId} {
      allow read: if true;
      allow create: if authExists();
      allow update: if authExists() && (isOwner(resource.data.capitan_uid) || esAdmin());
      allow delete: if esAdmin();
    }

    match /partidos_efootball/{partidoId} {
      allow read: if true;
      allow create: if authExists();
      allow update: if authExists() && (
        isOwner(resource.data.creado_por) || 
        isOwner(resource.data.equipo_local) || 
        isOwner(resource.data.equipo_visitante) || 
        esAdmin()
      );
      allow delete: if esAdmin();
    }

    match /chat_partidos/{chatId} {
      allow read: if authExists();
      allow create: if authExists();
      allow update, delete: if authExists() && (isOwner(resource.data.uid) || esAdmin());
    }

    match /cantina_messages/{msgId} {
      allow read: if authExists();
      allow create: if authExists()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.texto is string
                    && request.resource.data.texto.size() <= 280;
      allow update: if authExists()
                    && (request.auth.uid == "2bOrFxTAcPgFPoHKJHQfYxoQJpw1"
                        || obtenerRol() == "soporte"
                        || obtenerRol() == "mod")
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['deleted']);
      allow delete: if authExists()
                    && (request.auth.uid == "2bOrFxTAcPgFPoHKJHQfYxoQJpw1"
                        || obtenerRol() == "soporte"
                        || obtenerRol() == "mod");
    }

    match /cantina_presencia/{userId} {
      allow read: if authExists();
      // Cada usuario solo puede escribir/borrar su propio doc de presencia
      allow write: if authExists() && request.auth.uid == userId;
    }

    match /community_streams/{streamUid} {
      allow read: if authExists();
      // Cada usuario puede crear/actualizar solo su propio canal (uid == doc ID)
      allow create, update: if authExists() && request.auth.uid == streamUid
                            && request.resource.data.keys().hasAll(['uid','nombre','plataforma','canal','juego'])
                            && request.resource.data.uid == request.auth.uid
                            && request.resource.data.plataforma in ['twitch','kick','youtube']
                            && request.resource.data.juego in ['FC26','EFOOTBALL','AMBOS'];
      allow delete: if authExists() && (request.auth.uid == streamUid || esAdmin());
    }

    match /leads_streamers/{leadId} {
      allow read: if esAdmin();
      allow create: if authExists()
                    && request.resource.data.keys().hasAll(['nombre', 'email'])
                    && request.resource.data.nombre is string
                    && request.resource.data.email is string;
      allow update, delete: if esAdmin();
    }

    // Tesorería LFA (10% fee de torneos) — solo lectura/escritura por servidor
    match /lfa_config/treasury {
      allow read: if esAdmin();
      allow write: if false; // solo el servidor Admin SDK puede modificar
    }

    // Log de movimientos de tesorería
    match /treasury_log/{docId} {
      allow read: if esAdmin();
      allow write: if false; // solo el servidor
    }

    // Reservas de cupo para torneos (15 min TTL, creadas por el servidor)
    match /reservas_torneo/{reservaId} {
      // El jugador puede leer su propia reserva
      allow read: if authExists() && (request.auth.uid == resource.data.uid || esAdmin());
      // Solo el servidor puede crear/actualizar (via Admin SDK)
      allow create, update, delete: if false;
    }

    // Alertas internas para el CEO (solo server puede crear)
    match /alertas_ceo/{docId} {
      allow read: if esAdmin();
      allow update: if esAdmin(); // para marcar revisado
      allow create, delete: if false; // solo el servidor crea
    }

    // Locks de idempotencia para joinTournament (solo servidor Admin SDK)
    match /join_locks/{lockId} {
      allow read, write: if false;
    }

    // Logs de Vision AI (solo CEO puede leer, solo servidor puede escribir)
    match /vision_logs/{logId} {
      allow read: if esAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
