rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Avatares de perfil ────────────────────────────────────────
    // Ruta: avatars/{userId}
    // Solo el propio usuario puede subir/sobreescribir su avatar
    // Máx 2 MB, solo imágenes JPEG/PNG/WEBP
    match /avatars/{userId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size <= 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // ── Evidencias de partidos (marcadores eFootball / FC26) ──────
    // Ruta: results/{tournamentId}/{matchId}/{timestamp}
    // Solo usuarios autenticados pueden subir
    // Máx 5 MB, solo imágenes JPEG/PNG
    match /results/{tournamentId}/{matchId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png)');
    }

    // ── Evidencias VAR (ruta legacy) ──────────────────────────────
    // Ruta: var_evidencias/{torneoId}/{userId}_{timestamp}.jpg
    match /var_evidencias/{torneoId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size <= 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png)');
    }

    // ── Bloquear todo lo demás ───────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}